# Public site URL (no trailing slash). Used in vite.config for canonical, Open Graph, and
# Twitter meta tags in index.html, and exposed to the app as import.meta.env.VITE_SITE_URL.
# Copy to .env and set your real domain for production. Example: https://yoursite.com
VITE_SITE_URL=https://example.com

# Optional: external analytics script URL (e.g. Plausible). Leave unset to disable.
# VITE_ANALYTICS_SCRIPT_URL=https://plausible.io/js/script.js
